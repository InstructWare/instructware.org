# Default deny: only publish explicitly allowed files/directories.
*

# Keep repository metadata.
!.gitignore
!.github/
!.github/workflows/
!.github/workflows/ci.yml

# Keep public project assets.
!README.md
!LICENSE
!.iwp-lint.yaml
!_ir/
!_ir/**
!protocol/
!protocol/**
!schema/
!schema/**
!whitepaper/
!whitepaper/**
!InstructWare.iw/
!InstructWare.iw/**

# Exclude generated/development artifacts even inside allowed trees.
_ir/node_modules/
_ir/.vitepress/cache
_ir/.vitepress/dist
.iwp/
out/
.tmp_iwp_build_tests/
.tmp_iwp_e2e_tests/
.tmp_iwp_lint_tests/
.cursor/
.venv/
.uv-cache/
.ruff_cache/
.idea/
.DS_Store

# Keep tools as a standalone nested repository only.
tools/
